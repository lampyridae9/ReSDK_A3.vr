      "layout_direction":0,
      "port_deletion_allowed":false,
      "subgraph_session":{},
      "custom":{
        "Цель":"Объект IWritableContentItem",
        "Текст":"Парняги! Записал всё сюда. Если что-то со мной случится, следуйте плану.\n\nКоротко, но по делу: сначала надо проверить, лежит ли чемодан под столом в сарае около заваленного тоннеля. Если лежит, и внутри звяки, то надо двигать в пустую хату на верхотуре. Чемодан оставьте там. И чуть не забыл: Заведующего надо умертвить, это обязательно, иначе не заплатят вам. Надеюсь, никто это не будет читать вслух. И посторонние тоже!"
      },
      "class_":"methods.IWritableContentItem.appendText_0"
    },
